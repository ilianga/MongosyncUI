# MongosyncUI environment variables.
# Copy to `.env.local` and adjust. All are OPTIONAL for a purely-localhost dev run.

# Session-cookie signing secret. A localhost dev fallback is used if unset, but you
# MUST set a strong, random value for ANY non-localhost use (otherwise sessions are
# forgeable). Generate one with, e.g.: openssl rand -hex 32
MSYNC_AUTH_SECRET=

# Override the data directory (default: ~/.mongosync-ui). Holds the SQLite database,
# generated configs, uploaded TLS certs, logs, and supervision state.
MONGOSYNC_UI_DIR=

# Note: the HTTP port is not an env var — pass it to Next.js with `-p`, e.g.:
#   npm run dev -- -p 4000
#   npm run start -- -p 4000
